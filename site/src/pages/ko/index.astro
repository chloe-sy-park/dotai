---
import Layout from "../../layouts/Layout.astro";
import { registry } from "../../lib/registry";
import { t } from "../../i18n/messages";

const locale = "ko";
const i = t(locale);
---

<Layout title={`${i.site_title} — ${i.tagline}`} locale={locale}>
  <main class="mx-auto max-w-3xl px-6 py-16">
    <header class="mb-10">
      <h1 class="text-4xl font-bold tracking-tight">{i.site_title}</h1>
      <p class="mt-3 text-lg text-zinc-600">{i.tagline}</p>
      <p class="mt-1 text-sm text-zinc-500">{i.asset_count(registry.count)}</p>
    </header>

    <ul class="space-y-4">
      {registry.assets.map((asset) => (
        <li class="rounded-lg border border-zinc-200 bg-white p-4">
          <div class="flex items-baseline justify-between gap-3">
            <h2 class="text-base font-semibold">{asset.title.ko ?? asset.title.en}</h2>
            <span class="text-xs uppercase tracking-wide text-zinc-500">
              {asset.ai_tool ?? "mcp"} · {asset.command_type ?? asset.asset_type}
            </span>
          </div>
          <p class="mt-1 text-sm text-zinc-600">
            {asset.description.ko ?? asset.description.en}
          </p>
          <p class="mt-2 text-xs text-zinc-500">{i.by} {asset.author} · {asset.license}</p>
        </li>
      ))}
    </ul>
  </main>
</Layout>
