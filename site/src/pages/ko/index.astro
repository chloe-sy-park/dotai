---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import AssetCard from "../../components/AssetCard.astro";
import { registry } from "../../lib/registry";
import { localePath, t } from "../../i18n/messages";

const locale = "ko";
const i = t(locale);
const featured = registry.assets.slice(0, 6);
---

<Layout title={`${i.site_title} — ${i.tagline}`} locale={locale}>
  <Header locale={locale} />

  <main class="mx-auto max-w-3xl px-6 py-16">
    <header class="mb-10">
      <h1 class="text-4xl font-bold tracking-tight">{i.site_title}</h1>
      <p class="mt-3 text-lg text-zinc-600">{i.tagline}</p>
      <p class="mt-1 text-sm text-zinc-500">{i.asset_count(registry.count)}</p>
      <a
        href={localePath(locale, "/browse")}
        class="mt-5 inline-block rounded-md bg-zinc-900 px-4 py-2 text-sm font-medium text-white hover:bg-zinc-700"
      >
        {i.browse} →
      </a>
    </header>

    <ul class="grid gap-3">
      {featured.map((asset) => (
        <li><AssetCard asset={asset} locale={locale} /></li>
      ))}
    </ul>
  </main>
</Layout>
